# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth
NEXTAUTH_SECRET=generate_a_random_32_character_string_here
NEXTAUTH_URL=http://localhost:3000

# Resend (email OTP) - get free key at resend.com
RESEND_API_KEY=re_your_key_here

# Google Gemini (AI assistant) - free at aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Neon PostgreSQL - free at neon.tech
DATABASE_URL=postgresql://user:password@host/aegis-db

# MongoDB Atlas - free at mongodb.com/atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aegis

# Upstash Redis - free at upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# OpenChargeMap - free at openchargemap.io
OCMAP_API_KEY=your_key_here

# CO2 Signal (grid carbon) - free at electricitymaps.com
CO2SIGNAL_API_KEY=your_key_here

# Test mode (set to "true" during development)
NEXT_PUBLIC_TEST_MODE=true
