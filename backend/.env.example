# Copy to .env and fill in real values
TEST_MODE=true
SECRET_KEY=change-this-to-a-random-64-character-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Databases
DATABASE_URL=postgresql+asyncpg://user:pass@host/aegis
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/aegis
REDIS_URL=redis://localhost:6379

# AI
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
OLLAMA_BASE_URL=http://localhost:11434

# External APIs
CO2SIGNAL_API_KEY=your_co2signal_key
OCMAP_API_KEY=your_ocmap_key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-domain.vercel.app
